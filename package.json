{
  "name": "agenticscope",
  "version": "1.1.1",
  "description": "A directory-as-context standard plus a read-only MCP server that gives AI agents live, structured, token-budgeted awareness of a multi-project workspace.",
  "type": "module",
  "license": "MIT",
  "author": "Jesse B Ngolab <jessengolab.dev@gmail.com>",
  "homepage": "https://github.com/jessn-dev/agentic-scope#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jessn-dev/agentic-scope.git"
  },
  "bugs": {
    "url": "https://github.com/jessn-dev/agentic-scope/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "agenticscope": "dist/cli.js",
    "agenticscope-mcp": "dist/mcp/server.js"
  },
  "files": [
    "dist",
    "schema",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:cli": "tsx src/cli.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "release": "semantic-release"
  },
  "keywords": [
    "ai",
    "agents",
    "mcp",
    "model-context-protocol",
    "context",
    "claude",
    "llm",
    "tokens"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "commander": "^12.1.0",
    "gpt-tokenizer": "^2.9.0",
    "picomatch": "^4.0.2",
    "simple-git": "^3.27.0",
    "smol-toml": "^1.3.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.10.0",
    "@types/picomatch": "^3.0.1",
    "semantic-release": "^24.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
